# Copy this file to .env.local and fill in your values (and set the same in Vercel).

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Membership payments ---
# Stripe secret key (server-side only — never commit). Card payments stay disabled until this is set.
STRIPE_SECRET_KEY=sk_live_or_test_xxx
# Public payment handles shown to members for manual payments:
NEXT_PUBLIC_VENMO_HANDLE=@Your-Venmo
NEXT_PUBLIC_ZELLE_HANDLE=you@example.com
# Optional: canonical site URL for Stripe redirect (defaults to the deployment URL).
NEXT_PUBLIC_SITE_URL=https://livingwithcoyotes.org
